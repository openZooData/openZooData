# openZooData — Test-Konfiguration
# Diese Datei als .env kopieren (NICHT in Git einchecken)
#
# Schnellstart:
#   cp tests/.env.example tests/.env
#   # Werte ausfüllen
#   pytest tests/ -v -m "not slow"

# API-Zieladresse
BASE_URL=https://api.openzoodata.org

# App-Token (aus POST /api/v1/auth/app_register)
TEST_APP_TOKEN=

# Admin-Login für JWT-Tests
TEST_EMAIL=
TEST_PASSWORD=

# Zoo-Slugs
TEST_ZOO=zoo_test          # MUSS ein dedizierter Test-Zoo sein — niemals produktiver Zoo!
TEST_FEED_ZOO=zoo_berlin   # Read-only Feed/SQLite-Tests — kann produktiver Zoo sein

# Health-Check-Key (aus source/.env auf dem Server)
# Pflicht für test_status_details_correct_key im Safe-Smoke-Lauf
HEALTH_CHECK_KEY=

# Für Feedback-Tests
TEST_ENCLOSURE_ID=
TEST_SPECIES_ID=
TEST_ENRICHMENT_TEXT_ID=
