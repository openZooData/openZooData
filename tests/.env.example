# openZooData — Test-Konfiguration
# Diese Datei als .env kopieren (NICHT in Git einchecken)
#
# Schnellstart:
#   cp tests/.env.example tests/.env
#   # Werte ausfüllen
#   pytest tests/ -v -m "not slow"

# API-Zieladresse
BASE_URL=http://localhost:5001

# App-Token (aus POST /api/v1/auth/app_register)
TEST_APP_TOKEN=DEIN_APP_TOKEN_HIER

# Admin-Login für JWT-Tests
TEST_EMAIL=admin@example.org
TEST_PASSWORD=DeinPasswort!

# Zoo-Slugs
TEST_ZOO=zoo_test          # MUSS ein dedizierter Test-Zoo sein — niemals produktiver Zoo!
TEST_FEED_ZOO=zoo_test1   # Read-only Feed/SQLite-Tests — kann produktiver Zoo sein

# Health-Check-Key (aus source/.env auf dem Server)
# Pflicht für test_status_details_correct_key im Safe-Smoke-Lauf
HEALTH_CHECK_KEY=DEIN_HEALTH_CHECK_KEY_HIER
JWT_SECRET=DEIN_JWT_SECRET_HIER
RBAC_USER_PASSWORD=DeinSicheresTestPasswort!

# Für Feedback-Tests
TEST_ENCLOSURE_ID=66666
TEST_SPECIES_ID=66666
TEST_ENRICHMENT_TEXT_ID=66666
