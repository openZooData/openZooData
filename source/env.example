# openzoodata Server — variables

# ---------------------------------------------------------------------------
# Secrets (min. 32 chars)
# example: python3 -c "import secrets; print(secrets.token_hex(32))"
# ---------------------------------------------------------------------------
JWT_SECRET=
HEALTH_CHECK_KEY=

# ---------------------------------------------------------------------------
# Zoo-database (PostgreSQL)
# ---------------------------------------------------------------------------
PG_HOST=
PG_PORT=
PG_USER=
PG_PASSWORD=
PG_NAME=

# ---------------------------------------------------------------------------
# Auth-database (PostgreSQL)
# ---------------------------------------------------------------------------
AUTH_HOST=
AUTH_PORT=
AUTH_USER=
AUTH_PASSWORD=
AUTH_NAME=

# ---------------------------------------------------------------------------
# Redis for Rate-Limiting (optional)
# ---------------------------------------------------------------------------
# REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# public URL of the server
# ---------------------------------------------------------------------------
PUBLIC_BASE_URL=
