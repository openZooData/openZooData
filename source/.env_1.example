# openzoodata Server — Umgebungsvariablen
# Kopieren nach .env und Werte eintragen:
#   cp .env.example .env

# ---------------------------------------------------------------------------
# Pflicht-Secrets (min. 32 Zeichen, zufällig generieren)
# Beispiel: python3 -c "import secrets; print(secrets.token_hex(32))"
# ---------------------------------------------------------------------------
JWT_SECRET=
HEALTH_CHECK_KEY=

# ---------------------------------------------------------------------------
# Zoo-Datenbank (PostgreSQL)
# ---------------------------------------------------------------------------
PG_HOST=localhost
PG_PORT=5432
PG_USER=
PG_PASSWORD=
PG_NAME=zooguide

# ---------------------------------------------------------------------------
# Auth-Datenbank (PostgreSQL)
# ---------------------------------------------------------------------------
AUTH_HOST=localhost
AUTH_PORT=5432
AUTH_USER=
AUTH_PASSWORD=
AUTH_NAME=zooguide_auth

# ---------------------------------------------------------------------------
# Redis für Rate-Limiting (optional — ohne Redis wird in-memory verwendet)
# ---------------------------------------------------------------------------
# REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# Öffentliche URL dieses Servers
# ---------------------------------------------------------------------------
PUBLIC_BASE_URL=https://api.zooguide.app
